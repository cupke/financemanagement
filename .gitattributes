# Нормализация переводов строк для кросс-платформенной разработки.
# Любой текстовый файл хранится в репозитории с LF и выгружается с LF
# на любой ОС — даже если редактор на Windows переключится на CRLF,
# git нормализует перед коммитом.

* text=auto eol=lf

# ───── Явные текстовые форматы (на всякий случай) ─────
*.py        text eol=lf
*.pyi       text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.sh        text eol=lf
*.env       text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
LICENSE     text eol=lf
Dockerfile  text eol=lf
*.dockerignore text eol=lf

# ───── Windows-специфичные скрипты — оставляем CRLF ─────
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# ───── Бинарные форматы — git их не трогает ─────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.webp      binary
*.pdf       binary
*.docx      binary
*.xlsx      binary
*.pptx      binary
*.zip       binary
*.tar       binary
*.gz        binary
*.tgz       binary
*.7z        binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.db        binary
*.sqlite    binary
*.sqlite3   binary
