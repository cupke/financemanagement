# FinTrack backend — пример переменных окружения.
# Скопируйте в backend/.env и подставьте свои значения:
#   cp backend/.env.example backend/.env
# Файл .env в git НЕ коммитится (см. .gitignore); .env.example — коммитится как шаблон.

# ── Обязательные ───────────────────────────────────────────────────────────
# Секрет для подписи JWT. БЕЗ него приложение не стартует. Сгенерировать:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-a-long-random-string

# DSN PostgreSQL (async-драйвер asyncpg). При запуске через docker compose уже
# задаётся в docker-compose.yml — там эту строку в .env повторять НЕ нужно.
# Для запуска бэкенда вне Docker — раскомментируйте и укажите свою БД:
# DATABASE_URL=postgresql+asyncpg://fintrack:fintrack_dev_password@localhost:55432/fintrack

# ── JWT (необязательные, есть значения по умолчанию) ─────────────────────────
# JWT_ALGORITHM=HS256
# Время жизни access-токена в минутах (по умолчанию 10080 = 7 дней).
# JWT_ACCESS_TOKEN_EXPIRES_MINUTES=10080

# ── Окружение / CORS ─────────────────────────────────────────────────────────
# ENVIRONMENT=dev
# Список origin'ов фронтенда (JSON-массив). По умолчанию — dev-Vite на 60001.
# В проде укажите свой домен:
# CORS_ORIGINS=["https://fintrack.example"]

# ── Ссылки в письмах ─────────────────────────────────────────────────────────
# Базовый URL фронтенда — по нему строятся ссылки подтверждения/сброса пароля.
# Это адрес, который открывает БРАУЗЕР пользователя.
# FRONTEND_BASE_URL=http://127.0.0.1:60001

# ── Почта (выберите ОДИН режим) ──────────────────────────────────────────────
# 1) Режим лога: письма не отправляются, ссылка печатается в логах backend.
#    Удобно без почтового сервера.
# EMAIL_LOG_ONLY=true
#
# 2) Mailhog (docker compose --profile mail up -d): дефолт SMTP_HOST=mailhog
#    ловит письма на http://127.0.0.1:8025. Дополнительно ничего задавать не нужно.
#
# 3) Реальный SMTP (пример для Яндекс — implicit SSL на 465):
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USERNAME=you@yandex.ru
# SMTP_PASSWORD=app-password-here
# SMTP_USE_SSL=true
# SMTP_USE_TLS=false
# SMTP_FROM=FinTrack <you@yandex.ru>
#    (для STARTTLS-провайдеров вроде Gmail: порт 587, SMTP_USE_TLS=true, SMTP_USE_SSL=false)

# ── TTL одноразовых токенов (необязательные) ─────────────────────────────────
# EMAIL_VERIFY_TOKEN_TTL_HOURS=24
# PASSWORD_RESET_TOKEN_TTL_HOURS=1
